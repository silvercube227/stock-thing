# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# Direct Postgres connection (server-side ingestion, training jobs)
# Use the pooled connection string from Supabase > Project Settings > Database
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@HOST:5432/postgres

# SEC EDGAR requires a User-Agent header per their fair-access rules
SEC_EDGAR_USER_AGENT=stock-thing local dev your-email@example.com

# Local API
API_HOST=127.0.0.1
API_PORT=8000
